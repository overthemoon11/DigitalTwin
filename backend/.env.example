# LLM provider: "openai" (remote vLLM) or "foundry" (on-device Foundry Local)
# If OPENAI_BASE_URL is set, openai is used automatically unless LLM_PROVIDER=foundry
LLM_PROVIDER=openai

# Server port (default 3003)
# PORT=3003

# Company LLM via OpenVPN (OpenAI-compatible vLLM endpoint)
OPENAI_BASE_URL=http://10.211.9.95:8001/v1
OPENAI_MODEL=unsloth/Qwen3.6-35B-A3B-NVFP4
# OPENAI_API_KEY=optional-if-server-requires-auth

# Foundry Local (only when LLM_PROVIDER=foundry)
# FOUNDRY_MODEL=phi-3.5-mini
