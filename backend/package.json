{
  "name": "hvac-digital-twin-backend",
  "version": "2.0.0",
  "type": "module",
  "description": "Backend API for Smart Building HVAC Digital Twin",
  "main": "src/index.js",
  "scripts": {
    "prestart": "node --import ./src/load-env.js src/check-node-version.js",
    "start": "node --import ./src/load-env.js src/index.js",
    "predev": "node --import ./src/load-env.js src/check-node-version.js",
    "dev": "node --import ./src/load-env.js --watch src/index.js",
    "pretest": "node --import ./src/load-env.js src/check-node-version.js",
    "test": "node --test tests/*.test.js"
  },
  "keywords": ["hvac", "digital-twin", "simulation", "foundry-local"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "ws": "^8.14.2",
    "foundry-local-sdk": "^0.9.0"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=20.0.0"
  }
}
